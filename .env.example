# DataWiz environment template. Copy to .env and fill in local values.
# The MVP collects only secondary (publicly published) data, so no outlet
# credentials are required. These are placeholders for later sprints.

# --- Collection ---
# Override the default identifying User-Agent if the team standardises one.
DATAWIZ_USER_AGENT="DataWizBot/0.1 (+security-incident research)"

# --- PostgreSQL (Sprint 3 onward; Drive is interim storage until then) ---
# DATABASE_URL="postgresql://user:password@localhost:5432/datawiz"

# --- Media storage (under evaluation: Cloudinary / S3) ---
# CLOUDINARY_URL=
